# Copy this file to `.env` and fill in your Supabase project values.
# You can find them in your Supabase dashboard: Project Settings -> API.
#
# If these are left empty the site still works with sample products,
# but orders are only sent via WhatsApp (not saved to a database)
# and the admin panel stays locked.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
